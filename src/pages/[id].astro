---
import Layout from '../layouts/Layout.astro';
import solopreneurs from '../data/solopreneurs.json';

export function getStaticPaths() {
  return solopreneurs.map((s) => ({
    params: { id: s.id },
    props: { solopreneur: s },
  }));
}

const { solopreneur: s } = Astro.props;

const techLabels: Record<string, string> = {
  frontend: 'フロントエンド',
  backend: 'バックエンド',
  database: 'データベース',
  hosting: 'ホスティング',
  libraries: '主要ライブラリ',
  ai: 'AI/ML層',
};

const sourceLabels: Record<string, string> = {
  blog: 'ブログ記事',
  github: 'GitHubリポジトリ',
  podcast: 'Podcast / YouTube',
  x: 'SNS（X）',
};

const sourceIcons: Record<string, string> = {
  blog: '📄',
  github: '🐙',
  podcast: '🎙️',
  x: '🐦',
};

const certaintyLabels: Record<string, { text: string; color: string }> = {
  high: { text: '確信度: 高', color: 'bg-green-100 text-green-800' },
  medium: { text: '確信度: 中', color: 'bg-yellow-100 text-yellow-800' },
  low: { text: '確信度: 低', color: 'bg-red-100 text-red-800' },
};
---

<Layout 
  title={`${s.emoji ? `${s.emoji} ${s.name}` : s.name} - Solopreneurs Pages Dev`}
  description={`${s.emoji ? `${s.emoji} ${s.name}` : s.name}の技術スタック・開発環境・作ったもの`}
>
  <div class="mb-6">
    <a href="/" class="text-sm text-solo-600 hover:text-solo-900 underline">← 一覧に戻る</a>
  </div>

  <!-- Profile Header -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
    <div class="flex items-start gap-4">
      <div class="text-4xl">{s.flag}</div>
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{s.emoji ? `${s.emoji} ${s.name}` : s.name}</h1>
        <p class="text-gray-600">{s.country}</p>
        
        <div class="mt-3">
          <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">作ったもの</h2>
          <div class="space-y-2">
            {s.products.map(p => (
              <div class="flex items-center gap-2 flex-wrap">
                {p.url ? (
                  <a href={p.url} target="_blank" rel="noopener" class="text-sm bg-solo-50 text-solo-700 px-3 py-1 rounded-full font-medium hover:bg-solo-100 transition-colors shrink-0">{p.name}</a>
                ) : (
                  <span class="text-sm bg-solo-50 text-solo-700 px-3 py-1 rounded-full font-medium shrink-0">{p.name}</span>
                )}
                {p.description && (
                  <span class="text-xs text-gray-500">{p.description}</span>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Tech Stack -->
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
        ⚙️ 技術スタック
        <span class="text-xs font-normal text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">推測を含む</span>
      </h2>
      
      <div class="space-y-4">
        {Object.entries(s.techStack).map(([key, item]) => {
          const cert = certaintyLabels[item.certainty] || certaintyLabels.medium;
          return (
            <div class="border-b border-gray-100 last:border-0 pb-4 last:pb-0">
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm text-gray-500">{techLabels[key]}</span>
                <span class={`text-xs px-2 py-0.5 rounded-full ${cert.color}`}>{cert.text}</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-lg font-semibold text-gray-900">{item.value}</span>
                <span class="text-sm text-gray-400">
                  {item.sources.map((src: any) => (
                    <a href={src.url} target="_blank" rel="noopener" title={`${sourceLabels[src.type]}: ${src.title}`} class="hover:opacity-70 transition-opacity">
                      {sourceIcons[src.type] || src.type}
                    </a>
                  ))}
                </span>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Dev Tools -->
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
        🛠️ 開発環境・日々の作業
        <span class="text-xs font-normal text-gray-500 bg-gray-100 px-2 py-0.5 rounded-full">AI生産性ツール</span>
      </h2>
      
      <div class="space-y-4">
        <div class="border-b border-gray-100 pb-4">
          <span class="text-sm text-gray-500 block mb-1">コード補完・生成</span>
          <span class="text-lg font-semibold text-gray-900">
            {s.devTools.codeAI || <span class="text-gray-400 font-normal">非公開</span>}
          </span>
        </div>
        <div class="border-b border-gray-100 pb-4">
          <span class="text-sm text-gray-500 block mb-1">AIアシスタント</span>
          <span class="text-lg font-semibold text-gray-900">
            {s.devTools.assistant || <span class="text-gray-400 font-normal">非公開</span>}
          </span>
        </div>
        <div class="border-b border-gray-100 pb-4 last:border-0 last:pb-0">
          <span class="text-sm text-gray-500 block mb-1">UI生成・プロトタイピング</span>
          <span class="text-lg font-semibold text-gray-900">
            {s.devTools.uiGen || <span class="text-gray-400 font-normal">非公開</span>}
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- Business Strategy & Marketing -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">📊 ビジネス戦略</h2>
      <div class="space-y-3">
        {s.businessStrategy.map((item: any) => (
          <div>
            <span class="text-sm bg-blue-50 text-blue-700 px-3 py-1 rounded-full font-medium">{item.name}</span>
            <p class="text-sm text-gray-600 mt-1">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-lg font-bold text-gray-900 mb-4">📣 マーケティング手法</h2>
      <div class="space-y-3">
        {s.marketing.map((item: any) => (
          <div>
            <span class="text-sm bg-purple-50 text-purple-700 px-3 py-1 rounded-full font-medium">{item.name}</span>
            <p class="text-sm text-gray-600 mt-1">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- X Timeline -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 mt-6">
    <h2 class="text-lg font-bold text-gray-900 mb-4">🐦 話題のX投稿</h2>
    <div class="max-w-xl">
      <a 
        class="twitter-timeline" 
        href={`https://twitter.com/${s.xHandle}`}
        data-height="600"
        data-chrome="noheader nofooter transparent"
      >
        Tweets by {s.xHandle}
      </a>
    </div>
  </div>

  <!-- Sources -->
  <div class="bg-gray-50 rounded-xl border border-gray-200 p-6 mt-6">
    <h2 class="text-sm font-bold text-gray-700 mb-3">📋 情報源（公開情報の一覧）</h2>
    <ul class="text-sm text-gray-600 space-y-2">
      {Array.from(new Map(Object.values(s.techStack).flatMap((item: any) => item.sources).map((src: any) => [src.url, src])).values()).map((src: any) => (
        <li class="flex items-start gap-2">
          <span class="shrink-0">{sourceIcons[src.type] || ''}</span>
          <a href={src.url} target="_blank" rel="noopener" class="text-solo-600 hover:text-solo-900 hover:underline break-all">
            {src.title}
          </a>
        </li>
      ))}
    </ul>
    <p class="text-xs text-gray-500 mt-3">
      ※ 各情報源から技術スタックを抽出し、LLMによって推測・整理しています。
    </p>
  </div>
</Layout>
